# Production env for the recruiter dashboard on Vercel → app.interviehire.com
# Set these in the Vercel project's Environment Variables (Production scope).

# The hosted FastAPI backend on Render (auth, jobs, applicants, reports).
NEXT_PUBLIC_API_URL=https://interviehire-backend.onrender.com/api

# The candidate interview room (the apps/web Vercel project) — used by the
# "Run test interview" launcher to open the room.
NEXT_PUBLIC_ENGINE_WEB_URL=https://interviehire.com
