# Server-side key for the /api/deepseek proxy. Required — the route returns 500 without it.
# Local dev: copy to .env.local and fill in. Vercel: set it under Project Settings → Environment Variables.
DEEPSEEK_API_KEY=

# Base URL of the FastAPI backend (auth + live data). Defaults to http://localhost:8000/api.
# In production point this at your hosted backend, e.g. https://api.yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api
