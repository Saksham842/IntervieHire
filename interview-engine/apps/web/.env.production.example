# Production env for the candidate site (apps/web) on Vercel → interviehire.com
# Set these in the Vercel project's Environment Variables (Production scope).

# The hosted Fastify engine on Render (sessions + transcript + report + WS).
NEXT_PUBLIC_API_URL=https://interviehire-engine.onrender.com
NEXT_PUBLIC_WS_URL=wss://interviehire-engine.onrender.com/ws

# The avatar's STABLE public stream URL — the Cloudflare named tunnel to the
# UE5 Pixel Streaming player running on your PC (see DEPLOY.md → Avatar).
NEXT_PUBLIC_AVATAR_URL=https://avatar.interviehire.com
